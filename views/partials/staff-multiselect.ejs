<%# Staff multiselect: chips for selected, search in dropdown.
    Locals: staff, selectedIds, inputName ('staff_ids'), inputId (optional), placeholderText, searchPlaceholder %>
<%
  const name = typeof inputName !== 'undefined' ? inputName : 'staff_ids';
  const selected = Array.isArray(selectedIds) ? selectedIds.map(String) : [];
  const id = 'staff-multiselect-' + (typeof inputId !== 'undefined' ? inputId : 'default');
  const staffList = staff || [];
  const placeholder = typeof placeholderText !== 'undefined' ? placeholderText : 'Choose staff...';
  const searchText = typeof searchPlaceholder !== 'undefined' ? searchPlaceholder : 'Search staff...';
%>
<div class="staff-multiselect" id="<%= id %>" data-input-name="<%= name %>">
  <div class="staff-multiselect-trigger"
       role="combobox"
       aria-expanded="false"
       aria-haspopup="listbox"
       tabindex="0">
    <div class="staff-multiselect-chips-wrap">
      <% if (selected.length === 0) { %>
        <span class="staff-multiselect-placeholder"><%= placeholder %></span>
      <% } else {
        selected.forEach((sid) => {
          const s = staffList.find(x => String(x.id) === sid);
          if (!s) return;
      %>
        <span class="staff-multiselect-chip" data-value="<%= s.id %>">
          <span class="staff-multiselect-chip-label"><%= s.name %></span>
          <button type="button" class="staff-multiselect-chip-remove" aria-label="Remove <%= s.name %>">&times;</button>
        </span>
      <% });
      } %>
    </div>
    <svg class="staff-multiselect-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
  <div class="staff-multiselect-dropdown hidden" role="listbox" aria-multiselectable="true">
    <div class="staff-multiselect-search-wrap">
      <span class="staff-multiselect-search-icon" aria-hidden="true">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
      </span>
      <input type="text" class="staff-multiselect-search" placeholder="<%= searchText %>" autocomplete="off" />
    </div>
    <div class="staff-multiselect-actions">
      <button type="button" class="staff-multiselect-select-all">Select all</button>
      <button type="button" class="staff-multiselect-clear">Clear</button>
    </div>
    <div class="staff-multiselect-list">
      <% staffList.forEach((s) => {
           const meta = s.meta || s.email || '';
      %>
        <label class="staff-multiselect-option" data-name="<%= (s.name + ' ' + meta).toLowerCase() %>">
          <input type="checkbox" class="staff-multiselect-checkbox" value="<%= s.id %>"
            <%= selected.includes(String(s.id)) ? 'checked' : '' %> />
          <span class="staff-multiselect-option-name"><%= s.name %></span>
          <% if (meta) { %>
            <span class="staff-multiselect-option-meta"><%= meta %></span>
          <% } %>
        </label>
      <% }) %>
    </div>
  </div>
  <div class="staff-multiselect-hidden-inputs" aria-hidden="true">
    <% selected.forEach((sid) => { %>
      <input type="hidden" name="<%= name %>[]" value="<%= sid %>" />
    <% }) %>
  </div>
</div>

<style>
  .staff-multiselect { position: relative; }
  .staff-multiselect-trigger {
    min-height: 42px;
    padding: 6px 10px 6px 12px;
    border: 1px solid var(--border-default, #d1d5db);
    border-radius: 8px;
    background: var(--bg-surface);
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .staff-multiselect-trigger:hover { border-color: var(--color-soft, #0d9488); }
  .staff-multiselect-trigger:focus {
    outline: none;
    border-color: var(--color-soft);
    box-shadow: 0 0 0 2px var(--accent-soft, rgba(14, 165, 233, 0.2));
  }
  .staff-multiselect-chips-wrap {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .staff-multiselect-placeholder {
    font-size: 14px;
    color: var(--text-muted);
  }
  .staff-multiselect-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 500;
    background: var(--bg-soft);
    color: var(--text-primary);
    border: 1px solid var(--border-light);
  }
  .staff-multiselect-chip-label { max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .staff-multiselect-chip-remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    padding: 0;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: var(--text-muted);
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .staff-multiselect-chip-remove:hover {
    background: var(--bg-muted);
    color: var(--color-dark);
  }
  .staff-multiselect-chevron {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--text-muted);
    transition: transform 0.2s;
  }
  .staff-multiselect.open .staff-multiselect-chevron { transform: rotate(180deg); }
  .staff-multiselect-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 4px;
    background: var(--bg-surface);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    box-shadow: var(--shadow-lg);
    z-index: 50;
    overflow: hidden;
  }
  .staff-multiselect-dropdown.hidden { display: none !important; }
  .staff-multiselect-search-wrap {
    position: relative;
    padding: 8px;
    border-bottom: 1px solid var(--border-light);
  }
  .staff-multiselect-search {
    width: 100%;
    height: 36px;
    padding: 0 10px 0 34px;
    font-size: 13px;
    border: 1px solid var(--border-default);
    border-radius: 6px;
    background: var(--bg-surface);
    color: var(--text-primary);
    outline: none;
  }
  .staff-multiselect-search:focus { border-color: var(--color-soft); }
  .staff-multiselect-search-wrap .staff-multiselect-search-icon {
    position: absolute;
    left: 14px;
    top: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    color: var(--text-muted);
  }
  .staff-multiselect-actions {
    display: flex;
    gap: 8px;
    padding: 6px 8px;
    border-bottom: 1px solid var(--border-light);
    background: var(--bg-soft);
  }
  .staff-multiselect-actions button {
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 500;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    background: transparent;
    color: var(--color-soft);
  }
  .staff-multiselect-actions .staff-multiselect-clear { color: var(--text-muted); }
  .staff-multiselect-actions button:hover { text-decoration: underline; }
  .staff-multiselect-list {
    max-height: 220px;
    overflow-y: auto;
    padding: 4px;
  }
  .staff-multiselect-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .staff-multiselect-option:hover { background: var(--bg-soft); }
  .staff-multiselect-option.staff-multiselect-option-hidden { display: none; }
  .staff-multiselect-checkbox { flex-shrink: 0; accent-color: var(--color-soft); }
  .staff-multiselect-option-name { font-size: 13px; font-weight: 500; color: var(--text-primary); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; }
  .staff-multiselect-option-meta { font-size: 12px; color: var(--text-muted); flex-shrink: 0; max-width: 160px; overflow: hidden; text-overflow: ellipsis; }
</style>

<script>
  (function () {
    var root = document.getElementById('<%= id %>');
    if (!root) return;
    var trigger = root.querySelector('.staff-multiselect-trigger');
    var dropdown = root.querySelector('.staff-multiselect-dropdown');
    var chipsWrap = root.querySelector('.staff-multiselect-chips-wrap');
    var searchInput = root.querySelector('.staff-multiselect-search');
    var checkboxes = root.querySelectorAll('.staff-multiselect-checkbox');
    var options = root.querySelectorAll('.staff-multiselect-option');
    var hiddenContainer = root.querySelector('.staff-multiselect-hidden-inputs');
    var inputName = root.getAttribute('data-input-name');
    var placeholderText = <%- JSON.stringify(placeholder) %>;

    function getNameForId(id) {
      var opt = root.querySelector('.staff-multiselect-option .staff-multiselect-checkbox[value="' + id + '"]');
      if (!opt) return '';
      var label = opt.closest('label');
      var nameEl = label ? label.querySelector('.staff-multiselect-option-name') : null;
      return nameEl ? nameEl.textContent : '';
    }

    function getSelectedValues() {
      var values = [];
      checkboxes.forEach(function (cb) {
        if (cb.checked) values.push(cb.value);
      });
      return values;
    }

    function syncHiddenInputs() {
      var values = getSelectedValues();
      hiddenContainer.innerHTML = '';
      values.forEach(function (v) {
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = inputName + '[]';
        input.value = v;
        hiddenContainer.appendChild(input);
      });
    }

    function renderChips() {
      var values = getSelectedValues();
      chipsWrap.innerHTML = '';
      if (values.length === 0) {
        var placeholder = document.createElement('span');
        placeholder.className = 'staff-multiselect-placeholder';
        placeholder.textContent = placeholderText;
        chipsWrap.appendChild(placeholder);
        return;
      }
      values.forEach(function (val) {
        var name = getNameForId(val);
        var chip = document.createElement('span');
        chip.className = 'staff-multiselect-chip';
        chip.setAttribute('data-value', val);
        chip.innerHTML = '<span class="staff-multiselect-chip-label">' + escapeHtml(name) + '</span><button type="button" class="staff-multiselect-chip-remove" aria-label="Remove ' + escapeHtml(name) + '">&times;</button>';
        var removeBtn = chip.querySelector('.staff-multiselect-chip-remove');
        removeBtn.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          var cb = root.querySelector('.staff-multiselect-checkbox[value="' + val + '"]');
          if (cb) { cb.checked = false; updateFromCheckboxes(); }
        });
        chipsWrap.appendChild(chip);
      });
    }

    function escapeHtml(s) {
      var div = document.createElement('div');
      div.textContent = s;
      return div.innerHTML;
    }

    function updateFromCheckboxes() {
      syncHiddenInputs();
      renderChips();
    }

    function filterList(query) {
      var q = (query || '').toLowerCase().trim();
      options.forEach(function (opt) {
        var text = (opt.getAttribute('data-name') || '').toLowerCase();
        opt.classList.toggle('staff-multiselect-option-hidden', q && text.indexOf(q) === -1);
      });
    }

    root.querySelector('.staff-multiselect-select-all').addEventListener('click', function () {
      options.forEach(function (opt) {
        if (!opt.classList.contains('staff-multiselect-option-hidden')) {
          var cb = opt.querySelector('.staff-multiselect-checkbox');
          if (cb) cb.checked = true;
        }
      });
      updateFromCheckboxes();
    });

    root.querySelector('.staff-multiselect-clear').addEventListener('click', function () {
      checkboxes.forEach(function (cb) { cb.checked = false; });
      updateFromCheckboxes();
    });

    if (searchInput) {
      searchInput.addEventListener('input', function () { filterList(this.value); });
      searchInput.addEventListener('keydown', function (e) {
        e.stopPropagation();
        if (e.key === 'Escape') { this.value = ''; filterList(''); this.blur(); }
      });
    }

    checkboxes.forEach(function (cb) {
      cb.addEventListener('change', updateFromCheckboxes);
    });

    function open() {
      root.classList.add('open');
      dropdown.classList.remove('hidden');
      trigger.setAttribute('aria-expanded', 'true');
      if (searchInput) {
        searchInput.value = '';
        filterList('');
        searchInput.focus();
      }
    }

    function close() {
      root.classList.remove('open');
      dropdown.classList.add('hidden');
      trigger.setAttribute('aria-expanded', 'false');
    }

    trigger.addEventListener('click', function () {
      if (dropdown.classList.contains('hidden')) open(); else close();
    });

    trigger.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        if (dropdown.classList.contains('hidden')) open(); else close();
      }
      if (e.key === 'Escape') close();
    });

    document.addEventListener('click', function (e) {
      if (!root.contains(e.target)) close();
    });

    updateFromCheckboxes();
  })();
</script>
