<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Task' %> | Task Management System</title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="icon" href="/favicon.ico" />
</head>
<body>
  <div class="h-screen flex flex-col">
    <header style="border-bottom: 1px solid var(--border-light); background-color: var(--bg-surface);">
      <div class="w-full px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2.5 text-sm font-semibold tracking-tight" style="color: var(--color-dark);">
          <img src="/favicon.ico" alt="Logo" class="w-8 h-8 rounded-lg object-contain" />
          <span>Task Management System</span>
        </a>
      </div>
    </header>

    <div class="flex flex-1 overflow-hidden">
      <%- include('sidebar') %>
      <main class="flex-1 overflow-y-auto px-4 sm:px-6 lg:px-8 py-6 pb-24 lg:pb-6">
        <div class="mx-auto w-full max-w-6xl">
