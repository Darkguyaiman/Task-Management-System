<%# KPI multiselect component.
    Locals: categories, selectedIds, inputName ('kpi_category_ids'), inputId (optional), placeholderText, searchPlaceholder %>
<%
  const name = typeof inputName !== 'undefined' ? inputName : 'kpi_category_ids';
  const selected = Array.isArray(selectedIds) ? selectedIds.map(String) : [];
  const id = 'kpi-multiselect-' + (typeof inputId !== 'undefined' ? inputId : 'default');
  const list = categories || [];
  const placeholder = typeof placeholderText !== 'undefined' ? placeholderText : 'Choose KPI categories...';
  const searchText = typeof searchPlaceholder !== 'undefined' ? searchPlaceholder : 'Search KPI categories...';
%>
<div class="kpi-multiselect" id="<%= id %>" data-input-name="<%= name %>">
  <div class="kpi-multiselect-trigger" role="combobox" aria-expanded="false" aria-haspopup="listbox" tabindex="0">
    <div class="kpi-multiselect-chips-wrap">
      <% if (selected.length === 0) { %>
        <span class="kpi-multiselect-placeholder"><%= placeholder %></span>
      <% } else {
        selected.forEach((sid) => {
          const item = list.find(x => String(x.id) === sid);
          if (!item) return;
      %>
        <span class="kpi-multiselect-chip" data-value="<%= item.id %>">
          <span class="kpi-multiselect-chip-label"><%= item.name %></span>
          <button type="button" class="kpi-multiselect-chip-remove" aria-label="Remove <%= item.name %>">&times;</button>
        </span>
      <% });
      } %>
    </div>
    <svg class="kpi-multiselect-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
  <div class="kpi-multiselect-dropdown hidden" role="listbox" aria-multiselectable="true">
    <div class="kpi-multiselect-search-wrap">
      <span class="kpi-multiselect-search-icon" aria-hidden="true">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
      </span>
      <input type="text" class="kpi-multiselect-search" placeholder="<%= searchText %>" autocomplete="off" />
    </div>
    <div class="kpi-multiselect-actions">
      <button type="button" class="kpi-multiselect-select-all">Select all</button>
      <button type="button" class="kpi-multiselect-clear">Clear</button>
    </div>
    <div class="kpi-multiselect-list">
      <% list.forEach((item) => { %>
        <label class="kpi-multiselect-option" data-name="<%= String(item.name || '').toLowerCase() %>">
          <input type="checkbox" class="kpi-multiselect-checkbox" value="<%= item.id %>" <%= selected.includes(String(item.id)) ? 'checked' : '' %> />
          <span class="kpi-multiselect-option-name"><%= item.name %></span>
        </label>
      <% }) %>
    </div>
  </div>
  <div class="kpi-multiselect-hidden-inputs" aria-hidden="true">
    <% selected.forEach((sid) => { %>
      <input type="hidden" name="<%= name %>[]" value="<%= sid %>" />
    <% }) %>
  </div>
</div>

<style>
  .kpi-multiselect { position: relative; }
  .kpi-multiselect-trigger {
    min-height: 42px;
    padding: 6px 10px 6px 12px;
    border: 1px solid var(--border-default, #d1d5db);
    border-radius: 8px;
    background: var(--bg-surface);
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .kpi-multiselect-trigger:hover { border-color: var(--color-soft, #0d9488); }
  .kpi-multiselect-trigger:focus {
    outline: none;
    border-color: var(--color-soft);
    box-shadow: 0 0 0 2px var(--accent-soft, rgba(14, 165, 233, 0.2));
  }
  .kpi-multiselect-chips-wrap {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .kpi-multiselect-placeholder { font-size: 14px; color: var(--text-muted); }
  .kpi-multiselect-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 500;
    background: var(--bg-soft);
    color: var(--text-primary);
    border: 1px solid var(--border-light);
  }
  .kpi-multiselect-chip-label { max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .kpi-multiselect-chip-remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: var(--text-muted);
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
  }
  .kpi-multiselect-chevron {
    width: 18px;
    height: 18px;
    color: var(--text-muted);
    transition: transform 0.2s;
  }
  .kpi-multiselect.open .kpi-multiselect-chevron { transform: rotate(180deg); }
  .kpi-multiselect-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 4px;
    background: var(--bg-surface);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    box-shadow: var(--shadow-lg);
    z-index: 50;
    overflow: hidden;
  }
  .kpi-multiselect-dropdown.hidden { display: none !important; }
  .kpi-multiselect-search-wrap {
    position: relative;
    padding: 8px;
    border-bottom: 1px solid var(--border-light);
  }
  .kpi-multiselect-search {
    width: 100%;
    height: 36px;
    padding: 0 10px 0 34px;
    font-size: 13px;
    border: 1px solid var(--border-default);
    border-radius: 6px;
    background: var(--bg-surface);
    color: var(--text-primary);
    outline: none;
  }
  .kpi-multiselect-search-wrap .kpi-multiselect-search-icon {
    position: absolute;
    left: 14px;
    top: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    color: var(--text-muted);
  }
  .kpi-multiselect-actions {
    display: flex;
    gap: 8px;
    padding: 6px 8px;
    border-bottom: 1px solid var(--border-light);
    background: var(--bg-soft);
  }
  .kpi-multiselect-actions button {
    padding: 4px 10px;
    font-size: 12px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    background: transparent;
    color: var(--color-soft);
  }
  .kpi-multiselect-actions .kpi-multiselect-clear { color: var(--text-muted); }
  .kpi-multiselect-list { max-height: 220px; overflow-y: auto; padding: 4px; }
  .kpi-multiselect-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .kpi-multiselect-option:hover { background: var(--bg-soft); }
  .kpi-multiselect-option.kpi-multiselect-option-hidden { display: none; }
  .kpi-multiselect-checkbox { flex-shrink: 0; accent-color: var(--color-soft); }
  .kpi-multiselect-option-name { font-size: 13px; font-weight: 500; color: var(--text-primary); }
</style>

<script>
  (function () {
    var root = document.getElementById('<%= id %>');
    if (!root) return;
    var trigger = root.querySelector('.kpi-multiselect-trigger');
    var dropdown = root.querySelector('.kpi-multiselect-dropdown');
    var chipsWrap = root.querySelector('.kpi-multiselect-chips-wrap');
    var searchInput = root.querySelector('.kpi-multiselect-search');
    var checkboxes = root.querySelectorAll('.kpi-multiselect-checkbox');
    var options = root.querySelectorAll('.kpi-multiselect-option');
    var hiddenContainer = root.querySelector('.kpi-multiselect-hidden-inputs');
    var inputName = root.getAttribute('data-input-name');
    var placeholderText = <%- JSON.stringify(placeholder) %>;

    function getSelectedValues() {
      var values = [];
      checkboxes.forEach(function (cb) {
        if (cb.checked) values.push(cb.value);
      });
      return values;
    }

    function getNameForId(id) {
      var cb = root.querySelector('.kpi-multiselect-checkbox[value=\"' + id + '\"]');
      if (!cb) return '';
      var option = cb.closest('.kpi-multiselect-option');
      var nameEl = option ? option.querySelector('.kpi-multiselect-option-name') : null;
      return nameEl ? nameEl.textContent : '';
    }

    function syncHiddenInputs() {
      hiddenContainer.innerHTML = '';
      getSelectedValues().forEach(function (v) {
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = inputName + '[]';
        input.value = v;
        hiddenContainer.appendChild(input);
      });
    }

    function escapeHtml(s) {
      var div = document.createElement('div');
      div.textContent = s;
      return div.innerHTML;
    }

    function renderChips() {
      var values = getSelectedValues();
      chipsWrap.innerHTML = '';
      if (values.length === 0) {
        var placeholderEl = document.createElement('span');
        placeholderEl.className = 'kpi-multiselect-placeholder';
        placeholderEl.textContent = placeholderText;
        chipsWrap.appendChild(placeholderEl);
        return;
      }

      values.forEach(function (val) {
        var name = getNameForId(val);
        var chip = document.createElement('span');
        chip.className = 'kpi-multiselect-chip';
        chip.setAttribute('data-value', val);
        chip.innerHTML = '<span class=\"kpi-multiselect-chip-label\">' + escapeHtml(name) + '</span><button type=\"button\" class=\"kpi-multiselect-chip-remove\" aria-label=\"Remove ' + escapeHtml(name) + '\">&times;</button>';
        chip.querySelector('.kpi-multiselect-chip-remove').addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          var cb = root.querySelector('.kpi-multiselect-checkbox[value=\"' + val + '\"]');
          if (cb) {
            cb.checked = false;
            updateState();
          }
        });
        chipsWrap.appendChild(chip);
      });
    }

    function filterList(query) {
      var q = (query || '').toLowerCase().trim();
      options.forEach(function (option) {
        var name = (option.getAttribute('data-name') || '').toLowerCase();
        option.classList.toggle('kpi-multiselect-option-hidden', q && name.indexOf(q) === -1);
      });
    }

    function updateState() {
      syncHiddenInputs();
      renderChips();
    }

    root.querySelector('.kpi-multiselect-select-all').addEventListener('click', function () {
      options.forEach(function (option) {
        if (!option.classList.contains('kpi-multiselect-option-hidden')) {
          var cb = option.querySelector('.kpi-multiselect-checkbox');
          if (cb) cb.checked = true;
        }
      });
      updateState();
    });

    root.querySelector('.kpi-multiselect-clear').addEventListener('click', function () {
      checkboxes.forEach(function (cb) { cb.checked = false; });
      updateState();
    });

    checkboxes.forEach(function (cb) {
      cb.addEventListener('change', updateState);
    });

    if (searchInput) {
      searchInput.addEventListener('input', function () { filterList(this.value); });
    }

    function open() {
      root.classList.add('open');
      dropdown.classList.remove('hidden');
      trigger.setAttribute('aria-expanded', 'true');
      if (searchInput) {
        searchInput.value = '';
        filterList('');
        searchInput.focus();
      }
    }

    function close() {
      root.classList.remove('open');
      dropdown.classList.add('hidden');
      trigger.setAttribute('aria-expanded', 'false');
    }

    trigger.addEventListener('click', function () {
      if (dropdown.classList.contains('hidden')) open(); else close();
    });

    trigger.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        if (dropdown.classList.contains('hidden')) open(); else close();
      }
      if (e.key === 'Escape') close();
    });

    document.addEventListener('click', function (e) {
      if (!root.contains(e.target)) close();
    });

    updateState();
  })();
</script>
