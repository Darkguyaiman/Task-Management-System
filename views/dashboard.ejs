<%- include('partials/header') %>

<section class="space-y-8">
  <div>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Overview of workload and due tasks.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="stat-card" style="border-top: 3px solid var(--color-dark);">
      <p class="text-xs font-medium uppercase tracking-wide mb-3" style="color: var(--text-secondary);">Total Tasks</p>
      <p class="text-3xl font-semibold" style="color: var(--color-dark);"><%= summary.total_tasks %></p>
    </div>
    <div class="stat-card" style="border-top: 3px solid var(--color-soft);">
      <p class="text-xs font-medium uppercase tracking-wide mb-3" style="color: var(--text-secondary);">Completed</p>
      <p class="text-3xl font-semibold" style="color: var(--color-soft);"><%= summary.completed_tasks %></p>
    </div>
    <div class="stat-card" style="border-top: 3px solid var(--accent-primary);">
      <p class="text-xs font-medium uppercase tracking-wide mb-3" style="color: var(--text-secondary);">Pending</p>
      <p class="text-3xl font-semibold" style="color: var(--accent-primary);"><%= summary.pending_tasks %></p>
    </div>
    <div class="stat-card" style="border-top: 3px solid var(--danger);">
      <p class="text-xs font-medium uppercase tracking-wide mb-3" style="color: var(--text-secondary);">Due Today</p>
      <p class="text-3xl font-semibold" style="color: var(--danger);"><%= summary.due_today %></p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
