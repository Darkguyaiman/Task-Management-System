<%- include('partials/header') %>

<h1 class="mb-4">Dashboard</h1>

<div class="row g-3">
  <div class="col-12 col-md-6 col-lg-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <h2 class="h6 text-muted mb-2">Total Tasks</h2>
        <p class="display-6 mb-0"><%= summary.total_tasks %></p>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-6 col-lg-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <h2 class="h6 text-muted mb-2">Completed Tasks</h2>
        <p class="display-6 mb-0 text-success"><%= summary.completed_tasks %></p>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-6 col-lg-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <h2 class="h6 text-muted mb-2">Pending Tasks</h2>
        <p class="display-6 mb-0 text-warning"><%= summary.pending_tasks %></p>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-6 col-lg-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <h2 class="h6 text-muted mb-2">Due Today</h2>
        <p class="display-6 mb-0 text-danger"><%= summary.due_today %></p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>