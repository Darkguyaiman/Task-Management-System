<%- include('partials/header') %>

<section class="dashboard-shell space-y-6">
  <div class="dashboard-hero">
    <div>
      <p class="dashboard-eyebrow"><%= isAdmin ? 'Admin Analytics' : 'Personal Analytics' %></p>
      <h1 class="dashboard-title">Dashboard</h1>
      <% if (isAdmin) { %>
        <p class="dashboard-subtitle">Track organization health, delivery pace, and staff output in one place.</p>
      <% } else { %>
        <p class="dashboard-subtitle">Track your task flow and productivity with a focused personal view.</p>
      <% } %>
    </div>
    <div class="dashboard-hero-pill">
      <span>Completion</span>
      <strong><%= summary.completion_rate %>%</strong>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <article class="group rounded-2xl border border-slate-200 bg-white p-4 shadow-sm ring-1 ring-transparent transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md">
      <div class="flex items-start justify-between gap-3">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-500">Total Tasks</p>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-slate-100 text-slate-700 ring-1 ring-slate-200">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 6h11M9 12h11M9 18h11M5 6h.01M5 12h.01M5 18h.01" />
          </svg>
        </span>
      </div>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-slate-900"><%= summary.total_tasks %></p>
      <p class="mt-1 text-xs text-slate-500">All tracked tasks</p>
    </article>

    <article class="group rounded-2xl border border-emerald-200 bg-gradient-to-b from-white to-emerald-50/40 p-4 shadow-sm ring-1 ring-emerald-100 transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-3">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-emerald-700">Completed</p>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700 ring-1 ring-emerald-200">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
        </span>
      </div>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-emerald-900"><%= summary.completed_tasks %></p>
      <p class="mt-1 text-xs text-emerald-700"><%= summary.completion_rate %>% completion rate</p>
    </article>

    <article class="group rounded-2xl border border-blue-200 bg-white p-4 shadow-sm ring-1 ring-blue-100 transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-3">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-blue-700">In Progress</p>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-700 ring-1 ring-blue-200">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M12 3v18" />
          </svg>
        </span>
      </div>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-blue-900"><%= summary.in_progress_tasks %></p>
      <p class="mt-1 text-xs text-blue-700">Active right now</p>
    </article>

    <article class="group rounded-2xl border border-amber-200 bg-white p-4 shadow-sm ring-1 ring-amber-100 transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-3">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-amber-700">Pending</p>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-amber-100 text-amber-700 ring-1 ring-amber-200">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
            <circle cx="12" cy="12" r="9" />
          </svg>
        </span>
      </div>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-amber-900"><%= summary.pending_tasks %></p>
      <p class="mt-1 text-xs text-amber-700">Queued to start</p>
    </article>

    <article class="group rounded-2xl border border-rose-200 bg-white p-4 shadow-sm ring-1 ring-rose-100 transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-3">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-rose-700">Overdue</p>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-rose-100 text-rose-700 ring-1 ring-rose-200">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM12 15.75h.007v.007H12v-.007Z" />
          </svg>
        </span>
      </div>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-rose-900"><%= summary.overdue_tasks %></p>
      <p class="mt-1 text-xs text-rose-700">Needs attention</p>
    </article>

    <article class="group rounded-2xl border border-teal-200 bg-white p-4 shadow-sm ring-1 ring-teal-100 transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-3">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-teal-700">Due Today</p>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-teal-100 text-teal-700 ring-1 ring-teal-200">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z" />
          </svg>
        </span>
      </div>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-teal-900"><%= summary.due_today %></p>
      <p class="mt-1 text-xs text-teal-700">Deadline is today</p>
    </article>

    <article class="group rounded-2xl border border-indigo-200 bg-white p-4 shadow-sm ring-1 ring-indigo-100 transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-3">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-indigo-700">Due Next 7 Days</p>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-indigo-100 text-indigo-700 ring-1 ring-indigo-200">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z" />
          </svg>
        </span>
      </div>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-indigo-900"><%= summary.due_next_7_days %></p>
      <p class="mt-1 text-xs text-indigo-700">Near-term workload</p>
    </article>

    <% if (isAdmin) { %>
      <article class="group rounded-2xl border border-cyan-200 bg-white p-4 shadow-sm ring-1 ring-cyan-100 transition hover:-translate-y-0.5 hover:shadow-md">
        <div class="flex items-start justify-between gap-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-cyan-700">Total Staff</p>
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-cyan-100 text-cyan-700 ring-1 ring-cyan-200">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3-6.72c0-4.97-4.03-9-9-9s-9 4.03-9 9a9.094 9.094 0 0 0 3 6.72M12 12a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-6 8.28C7.67 21.37 9.75 22 12 22s4.33-.63 6-1.72" />
            </svg>
          </span>
        </div>
        <p class="mt-3 text-3xl font-semibold tracking-tight text-cyan-900"><%= summary.total_staff %></p>
        <p class="mt-1 text-xs text-cyan-700">Active contributors</p>
      </article>
    <% } else { %>
      <article class="group rounded-2xl border border-cyan-200 bg-white p-4 shadow-sm ring-1 ring-cyan-100 transition hover:-translate-y-0.5 hover:shadow-md">
        <div class="flex items-start justify-between gap-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-cyan-700">Productivity Score</p>
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-cyan-100 text-cyan-700 ring-1 ring-cyan-200">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.06 4.94 3.75 3.75" />
            </svg>
          </span>
        </div>
        <p class="mt-3 text-3xl font-semibold tracking-tight text-cyan-900"><%= summary.completion_rate %>%</p>
        <p class="mt-1 text-xs text-cyan-700">Based on completed tasks</p>
      </article>
    <% } %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="chart-card">
      <div class="chart-head">
        <h2><%= isAdmin ? 'Task Status (All Tasks)' : 'Task Status (My Tasks)' %></h2>
      </div>
      <div class="dashboard-chart-wrap">
        <canvas id="statusChart"></canvas>
      </div>
    </div>

    <div class="chart-card">
      <div class="chart-head">
        <h2><%= isAdmin ? 'Task Distribution by KPI Category' : 'My Tasks by KPI Category' %></h2>
      </div>
      <div class="dashboard-chart-wrap">
        <canvas id="kpiChart"></canvas>
      </div>
    </div>
  </div>

  <div class="chart-card">
    <div class="chart-head">
      <h2><%= isAdmin ? 'Upcoming Due Workload (Org Timeline)' : 'Upcoming Due Workload (My Timeline)' %></h2>
    </div>
    <div class="dashboard-chart-wrap dashboard-chart-tall">
      <canvas id="timelineChart"></canvas>
    </div>
  </div>

  <% if (isAdmin) { %>
    <div class="chart-card">
      <div class="chart-head">
        <h2>Top Staff Productivity</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="dashboard-table min-w-full text-sm">
          <thead>
            <tr>
              <th>Staff</th>
              <th>Completed</th>
              <th>Assigned</th>
              <th>Completion Rate</th>
            </tr>
          </thead>
          <tbody>
            <% if ((topPerformers || []).length === 0) { %>
              <tr>
                <td colspan="4" class="dashboard-empty">No staff productivity data yet.</td>
              </tr>
            <% } %>
            <% (topPerformers || []).forEach((staff) => { %>
              <tr>
                <td><strong><%= staff.name %></strong></td>
                <td><%= staff.completed_count %></td>
                <td><%= staff.assigned_count %></td>
                <td><span class="rate-chip"><%= staff.completion_rate %>%</span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</section>

<style>
  .dashboard-shell {
    position: relative;
  }

  .dashboard-hero {
    position: relative;
    overflow: hidden;
    border-radius: 18px;
    padding: 1.4rem 1.1rem;
    border: 1px solid var(--border-light);
    background:
      radial-gradient(circle at 90% 10%, rgba(229, 184, 11, 0.14) 0%, rgba(229, 184, 11, 0) 36%),
      radial-gradient(circle at 10% 80%, rgba(94, 141, 131, 0.16) 0%, rgba(94, 141, 131, 0) 40%),
      linear-gradient(120deg, #ffffff 0%, #f3f8f7 100%);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }

  .dashboard-eyebrow {
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.35rem;
  }

  .dashboard-title {
    font-size: 1.65rem;
    line-height: 1.2;
    font-weight: 700;
    color: var(--color-dark);
  }

  .dashboard-subtitle {
    margin-top: .4rem;
    font-size: 0.92rem;
    color: var(--text-muted);
    max-width: 54ch;
  }

  .dashboard-hero-pill {
    flex-shrink: 0;
    border: 1px solid #d8e5e1;
    background: rgba(255, 255, 255, 0.76);
    backdrop-filter: blur(4px);
    border-radius: 14px;
    padding: 0.65rem 0.85rem;
    display: grid;
    gap: 2px;
    min-width: 118px;
    text-align: right;
  }

  .dashboard-hero-pill span {
    font-size: 11px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: .06em;
  }

  .dashboard-hero-pill strong {
    font-size: 1.1rem;
    color: var(--color-dark);
    font-weight: 700;
  }

  .chart-card {
    border-radius: 16px;
    border: 1px solid var(--border-light);
    background: linear-gradient(180deg, #ffffff 0%, #fcfdfd 100%);
    box-shadow: var(--shadow-sm);
    padding: 0.95rem 1rem 1rem;
  }

  .chart-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.7rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px dashed var(--border-light);
  }

  .chart-head h2 {
    font-size: 0.9rem;
    line-height: 1.2;
    color: var(--text-primary);
    font-weight: 600;
  }

  .dashboard-chart-wrap {
    position: relative;
    width: 100%;
    min-height: 280px;
  }

  .dashboard-chart-tall {
    min-height: 320px;
  }

  .dashboard-table thead tr {
    border-bottom: 1px solid var(--border-light);
  }

  .dashboard-table th {
    text-align: left;
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--text-secondary);
    padding: 0.6rem 0.75rem;
  }

  .dashboard-table td {
    padding: 0.65rem 0.75rem;
    color: var(--text-secondary);
    border-top: 1px solid var(--border-light);
  }

  .dashboard-table td strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .dashboard-empty {
    color: var(--text-muted);
    text-align: center;
    padding: 1rem;
  }

  .rate-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.18rem 0.55rem;
    font-size: 12px;
    font-weight: 600;
    color: #0e7490;
    background: rgba(8, 145, 178, 0.13);
  }

  @media (max-width: 640px) {
    .dashboard-hero {
      flex-direction: column;
      align-items: stretch;
    }

    .dashboard-hero-pill {
      text-align: left;
      width: max-content;
    }

  }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  (function () {
    const chartData = <%- JSON.stringify(chartData || {}) %>;
    const status = chartData.status || [];
    const kpi = chartData.kpi || [];
    const dueTimeline = chartData.dueTimeline || [];

    const statusColors = {
      pending: '#f59e0b',
      in_progress: '#2563eb',
      completed: '#059669'
    };

    const chartFont = {
      family: "system-ui, -apple-system, Segoe UI, sans-serif",
      size: 11
    };

    Chart.defaults.color = '#576e6a';
    Chart.defaults.font = chartFont;

    const prettyStatus = function (key) {
      if (key === 'in_progress') return 'In Progress';
      if (key === 'pending') return 'Pending';
      if (key === 'completed') return 'Completed';
      return key || 'Unknown';
    };

    const sharedGridColor = 'rgba(87, 110, 106, 0.13)';

    const statusCtx = document.getElementById('statusChart');
    if (statusCtx) {
      new Chart(statusCtx, {
        type: 'doughnut',
        data: {
          labels: status.map(function (item) { return prettyStatus(item.label); }),
          datasets: [{
            data: status.map(function (item) { return item.value; }),
            backgroundColor: status.map(function (item) { return statusColors[item.label] || '#64748b'; }),
            borderColor: '#ffffff',
            borderWidth: 2
          }]
        },
        options: {
          maintainAspectRatio: false,
          cutout: '62%',
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                boxWidth: 10,
                boxHeight: 10,
                usePointStyle: true,
                pointStyle: 'circle',
                padding: 14
              }
            }
          }
        }
      });
    }

    const kpiCtx = document.getElementById('kpiChart');
    if (kpiCtx) {
      new Chart(kpiCtx, {
        type: 'bar',
        data: {
          labels: kpi.map(function (item) { return item.label; }),
          datasets: [{
            label: 'Tasks',
            data: kpi.map(function (item) { return item.value; }),
            backgroundColor: 'rgba(94, 141, 131, 0.85)',
            hoverBackgroundColor: 'rgba(94, 141, 131, 1)',
            borderRadius: 8,
            barThickness: 22,
            maxBarThickness: 26
          }]
        },
        options: {
          maintainAspectRatio: false,
          scales: {
            x: {
              grid: { display: false },
              ticks: { maxRotation: 0, autoSkip: true }
            },
            y: {
              beginAtZero: true,
              ticks: { precision: 0, stepSize: 1 },
              grid: { color: sharedGridColor }
            }
          },
          plugins: { legend: { display: false } }
        }
      });
    }

    const timelineCtx = document.getElementById('timelineChart');
    if (timelineCtx) {
      new Chart(timelineCtx, {
        type: 'line',
        data: {
          labels: dueTimeline.map(function (item) { return item.label; }),
          datasets: [{
            label: 'Tasks Due',
            data: dueTimeline.map(function (item) { return item.value; }),
            borderColor: '#1d4ed8',
            backgroundColor: 'rgba(29, 78, 216, 0.12)',
            fill: true,
            tension: 0.32,
            pointRadius: 3,
            pointHoverRadius: 4,
            pointBorderWidth: 2,
            pointBackgroundColor: '#ffffff'
          }]
        },
        options: {
          maintainAspectRatio: false,
          scales: {
            x: {
              grid: { display: false }
            },
            y: {
              beginAtZero: true,
              ticks: { precision: 0, stepSize: 1 },
              grid: { color: sharedGridColor }
            }
          },
          plugins: {
            legend: { display: false }
          }
        }
      });
    }
  })();
</script>

<%- include('partials/footer') %>
