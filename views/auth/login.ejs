<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Task Management System</title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="icon" href="/favicon.ico" />
</head>
<body class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="mb-8 text-center space-y-2">
      <img src="/QSS.webp" alt="Logo" class="w-14 h-14 rounded-xl object-contain mx-auto mb-3" />
      <h1 class="text-xl font-semibold tracking-tight" style="color: var(--color-dark);">
        Task Management System
      </h1>
      <p class="text-sm" style="color: var(--text-muted);">
        Sign in to continue.
      </p>
    </div>

    <div class="card space-y-5" style="box-shadow: var(--shadow-md);">
      <div class="space-y-1">
        <h2 class="text-sm font-semibold" style="color: var(--color-dark);">Login</h2>
        <p class="text-xs" style="color: var(--text-muted);">
          Enter your credentials to continue.
        </p>
      </div>

      <% if (formError) { %>
        <div class="error-alert"><%= formError %></div>
      <% } %>

      <form method="POST" action="/login" class="space-y-4">
        <div>
          <label for="email" class="form-label">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autofocus
            placeholder="you@example.com"
            class="input-field"
            value="<%= (oldInput && oldInput.email) || '' %>"
          />
        </div>

        <div>
          <label for="password" class="form-label">Password</label>
          <div class="relative">
            <input
              id="password"
              name="password"
              type="password"
              required
              placeholder="Enter your password"
              class="input-field"
              style="padding-right: 2.75rem;"
            />
            <button
              type="button"
              id="toggle-password"
              class="absolute right-0 top-0 h-full px-3 flex items-center justify-center cursor-pointer"
              style="color: var(--text-muted); background: none; border: none;"
              aria-label="Toggle password visibility"
            >
              <svg id="eye-show" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <svg id="eye-hide" class="w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
              </svg>
            </button>
          </div>
        </div>

        <button type="submit" class="btn-primary w-full">
          Sign in
        </button>
      </form>
    </div>
  </div>

  <script>
    document.getElementById('toggle-password').addEventListener('click', function () {
      var input = document.getElementById('password');
      var show = document.getElementById('eye-show');
      var hide = document.getElementById('eye-hide');
      if (input.type === 'password') {
        input.type = 'text';
        show.classList.add('hidden');
        hide.classList.remove('hidden');
      } else {
        input.type = 'password';
        show.classList.remove('hidden');
        hide.classList.add('hidden');
      }
    });
  </script>
</body>
</html>
