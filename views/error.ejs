<%- include('partials/header') %>

<section class="flex items-center justify-center py-16">
  <div class="max-w-md w-full">
    <div class="card space-y-4 text-center" style="box-shadow: var(--shadow-md);">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full mx-auto" style="background-color: var(--danger-soft); color: var(--danger);">
        <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
      </div>
      <div class="space-y-1">
        <h1 class="text-lg font-semibold" style="color: var(--color-dark);"><%= message %></h1>
        <% if (error) { %>
          <pre class="mt-3 text-xs rounded-lg px-3 py-2 overflow-auto text-left"
            style="background-color: var(--bg-soft); color: var(--text-muted);"><%= error.message %></pre>
        <% } %>
      </div>
      <div class="pt-2">
        <a href="/" class="btn-primary">Go to Dashboard</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
