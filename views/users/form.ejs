<%- include('../partials/header') %>

<%
  const isEdit = typeof user !== 'undefined' && user !== null;
  const heading = isEdit ? 'Edit User #' + user.id : 'Create User';
  const subtitle = isEdit ? 'Update user details.' : 'Add a new staff member.';
  const actionUrl = isEdit ? '/users/' + user.id + '/update' : '/users';
  const submitLabel = isEdit ? 'Update User' : 'Create User';

  const nameVal  = (typeof oldInput !== 'undefined' && oldInput.name)  ? oldInput.name  : (isEdit ? user.name  : '');
  const emailVal = (typeof oldInput !== 'undefined' && oldInput.email) ? oldInput.email : (isEdit ? user.email : '');
  const roleVal  = (typeof oldInput !== 'undefined' && oldInput.role)  ? oldInput.role  : (isEdit ? user.role  : 'staff');
  const desigVal = (typeof oldInput !== 'undefined' && oldInput.designation) ? oldInput.designation : (isEdit ? (user.designation || '') : '');
%>

<section class="space-y-8">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="page-title"><%= heading %></h1>
      <p class="page-subtitle"><%= subtitle %></p>
    </div>
    <a href="/users" class="btn-ghost">Back to Users</a>
  </div>

  <div>
    <div class="card space-y-5">
      <% if (typeof formError !== 'undefined' && formError) { %>
        <div class="error-alert"><%= formError %></div>
      <% } %>

      <form method="POST" action="<%= actionUrl %>" class="space-y-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label" for="name">Name</label>
            <input id="name" name="name" required class="input-field" placeholder="Full name"
              value="<%= nameVal %>" />
          </div>

          <div>
            <label class="form-label" for="email">Email</label>
            <input id="email" name="email" type="email" required class="input-field" placeholder="you@example.com"
              value="<%= emailVal %>" />
          </div>
        </div>

        <div>
          <label class="form-label" for="new-password">
            Password
            <% if (isEdit) { %>
              <span class="text-xs font-normal" style="color: var(--text-muted);">(leave blank to keep current)</span>
            <% } %>
          </label>
          <div class="relative">
            <input id="new-password" name="password" type="password"
              <%= isEdit ? '' : 'required' %> minlength="6"
              class="input-field" placeholder="Min. 6 characters"
              style="padding-right: 2.75rem;" />
            <button type="button" class="pw-toggle absolute right-0 top-0 h-full px-3 flex items-center justify-center cursor-pointer"
              style="color: var(--text-muted); background: none; border: none;" aria-label="Toggle password visibility">
              <svg class="eye-show w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <svg class="eye-hide w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
              </svg>
            </button>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label" for="role">Role</label>
            <select id="role" name="role" required class="input-field">
              <option value="staff" <%= roleVal === 'staff' ? 'selected' : '' %>>Staff</option>
              <option value="admin" <%= roleVal === 'admin' ? 'selected' : '' %>>Admin</option>
            </select>
          </div>

          <div>
            <label class="form-label" for="designation">Designation</label>
            <input id="designation" name="designation" class="input-field" placeholder="e.g. Project Manager"
              value="<%= desigVal %>" />
          </div>
        </div>

        <div class="flex items-center gap-3 pt-2">
          <button type="submit" class="btn-primary"><%= submitLabel %></button>
          <a href="/users" class="btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.pw-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var wrapper = this.closest('.relative');
      var input = wrapper.querySelector('input');
      var show = this.querySelector('.eye-show');
      var hide = this.querySelector('.eye-hide');
      if (input.type === 'password') {
        input.type = 'text';
        show.classList.add('hidden');
        hide.classList.remove('hidden');
      } else {
        input.type = 'password';
        show.classList.remove('hidden');
        hide.classList.add('hidden');
      }
    });
  });
</script>

<%- include('../partials/footer') %>
