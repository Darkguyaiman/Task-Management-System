<%- include('../partials/header') %>

<section class="space-y-8">
  <div>
    <h1 class="page-title">Users</h1>
    <p class="page-subtitle">Manage staff who can be assigned to tasks.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.6fr)] gap-6">
    <div class="card space-y-4">
      <h2 class="text-sm font-semibold" style="color: var(--color-dark);">Create User</h2>

      <% if (formError) { %>
        <div class="error-alert"><%= formError %></div>
      <% } %>

      <form method="POST" action="/users" class="space-y-4">
        <div>
          <label class="form-label" for="name">Name</label>
          <input id="name" name="name" required class="input-field" placeholder="Full name"
            value="<%= oldInput.name || '' %>" />
        </div>

        <div>
          <label class="form-label" for="email">Email</label>
          <input id="email" name="email" type="email" required class="input-field" placeholder="you@example.com"
            value="<%= oldInput.email || '' %>" />
        </div>

        <div>
          <label class="form-label" for="new-password">Password</label>
          <div class="relative">
            <input id="new-password" name="password" type="password" required minlength="6"
              class="input-field" placeholder="Min. 6 characters"
              style="padding-right: 2.75rem;" />
            <button type="button" class="pw-toggle absolute right-0 top-0 h-full px-3 flex items-center justify-center cursor-pointer"
              style="color: var(--text-muted); background: none; border: none;" aria-label="Toggle password visibility">
              <svg class="eye-show w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <svg class="eye-hide w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
              </svg>
            </button>
          </div>
        </div>

        <div class="pt-1">
          <button type="submit" class="btn-primary">Create User</button>
        </div>
      </form>
    </div>

    <div class="card space-y-4 overflow-hidden">
      <div>
        <h2 class="text-sm font-semibold" style="color: var(--color-dark);">User List</h2>
        <p class="text-xs mt-0.5" style="color: var(--text-muted);">
          <%= users.length %> user<%= users.length !== 1 ? 's' : '' %> registered.
        </p>
      </div>

      <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm" style="border-top: 1px solid var(--border-light);">
          <thead>
            <tr style="background-color: var(--bg-soft);">
              <th class="px-5 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">ID</th>
              <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Name</th>
              <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Email</th>
              <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Role</th>
              <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Created</th>
              <th class="px-5 py-2.5 text-right text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (users.length === 0) { %>
              <tr>
                <td colspan="6" class="px-5 py-10 text-center text-sm" style="color: var(--text-muted);">
                  No users found. Create one above.
                </td>
              </tr>
            <% } %>
            <% users.forEach((user) => { %>
              <tr class="table-row">
                <td class="px-5 py-3 align-top text-xs whitespace-nowrap" style="color: var(--text-muted);">#<%= user.id %></td>
                <td class="px-3 py-3 align-top">
                  <div class="flex items-center gap-2">
                    <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-semibold shrink-0"
                      style="background-color: var(--brand-soft); color: var(--color-soft);">
                      <%= user.name.charAt(0).toUpperCase() %>
                    </span>
                    <span class="text-sm font-medium"><%= user.name %></span>
                  </div>
                </td>
                <td class="px-3 py-3 align-top text-sm" style="color: var(--text-secondary);"><%= user.email %></td>
                <td class="px-3 py-3 align-top">
                  <% if (user.role === 'admin') { %>
                    <span class="badge badge-in-progress">Admin</span>
                  <% } else { %>
                    <span class="badge" style="background-color: var(--bg-soft); color: var(--text-secondary);">Staff</span>
                  <% } %>
                </td>
                <td class="px-3 py-3 align-top text-sm whitespace-nowrap" style="color: var(--text-secondary);">
                  <%= new Date(user.created_at).toLocaleDateString() %>
                </td>
                <td class="px-5 py-3 align-top text-right">
                  <form method="POST" action="/users/<%= user.id %>/delete" class="inline">
                    <button type="submit" class="btn-sm-danger"
                      onclick="return confirm('Delete this user? This also deletes related tasks.')">
                      Delete
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.pw-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var wrapper = this.closest('.relative');
      var input = wrapper.querySelector('input');
      var show = this.querySelector('.eye-show');
      var hide = this.querySelector('.eye-hide');
      if (input.type === 'password') {
        input.type = 'text';
        show.classList.add('hidden');
        hide.classList.remove('hidden');
      } else {
        input.type = 'password';
        show.classList.remove('hidden');
        hide.classList.add('hidden');
      }
    });
  });
</script>

<%- include('../partials/footer') %>
