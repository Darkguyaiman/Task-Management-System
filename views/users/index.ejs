<%- include('../partials/header') %>

<%
  const hasFilters = filters.search || filters.role || filters.designation;
%>

<section class="space-y-8">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="page-title">Users</h1>
      <p class="page-subtitle">Manage staff who can be assigned to tasks.</p>
    </div>
    <a href="/users/create" class="btn-primary">+ Add User</a>
  </div>

  <div class="card overflow-hidden" style="padding: 0;">
    <!-- Inline filter bar -->
    <form method="GET" action="/users"
      class="flex flex-wrap items-center gap-2 px-5 py-3"
      style="background-color: var(--bg-soft); border-bottom: 1px solid var(--border-light);">
      <div class="relative user-search-wrap" style="flex: 2 1 280px; min-width: 220px;">
        <span class="user-search-icon" style="color: var(--text-muted); pointer-events: none;">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </span>
        <input name="search" class="filter-input" style="width: 100%;"
          placeholder="Search by name, email or designation..."
          value="<%= filters.search || '' %>" />
      </div>

      <select name="role" class="filter-input" style="width: auto; min-width: 110px;">
        <option value="">All roles</option>
        <option value="admin" <%= filters.role === 'admin' ? 'selected' : '' %>>Admin</option>
        <option value="staff" <%= filters.role === 'staff' ? 'selected' : '' %>>Staff</option>
      </select>

      <select name="designation" class="filter-input" style="width: auto; min-width: 140px;">
        <option value="">All designations</option>
        <% designations.forEach(function(d) { %>
          <option value="<%= d %>" <%= filters.designation === d ? 'selected' : '' %>><%= d %></option>
        <% }) %>
      </select>

      <button type="submit" class="filter-btn filter-btn-apply">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" />
        </svg>
        Filter
      </button>

      <% if (hasFilters) { %>
        <a href="/users" class="filter-btn filter-btn-reset">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
          Clear
        </a>
      <% } %>
    </form>

    <!-- Table -->
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr style="background-color: var(--bg-surface); border-bottom: 1px solid var(--border-light);">
            <th class="px-5 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Name</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Email</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Role</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Designation</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Created</th>
            <th class="px-5 py-2.5 text-center text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (users.length === 0) { %>
            <tr>
              <td colspan="6" class="px-5 py-10 text-center text-sm" style="color: var(--text-muted);">
                No users found. <a href="/users/create" style="color: var(--color-soft); text-decoration: underline;">Create one</a>.
              </td>
            </tr>
          <% } %>
          <% users.forEach((user) => { %>
            <tr class="table-row">
              <td class="px-5 py-3 align-top">
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-semibold shrink-0"
                    style="background-color: var(--brand-soft); color: var(--color-soft);">
                    <%= user.name.charAt(0).toUpperCase() %>
                  </span>
                  <span class="text-sm font-medium"><%= user.name %></span>
                </div>
              </td>
              <td class="px-3 py-3 align-top text-sm" style="color: var(--text-secondary);"><%= user.email %></td>
              <td class="px-3 py-3 align-top">
                <% if (user.role === 'admin') { %>
                  <span class="badge badge-in-progress">Admin</span>
                <% } else { %>
                  <span class="badge" style="background-color: var(--bg-soft); color: var(--text-secondary);">Staff</span>
                <% } %>
              </td>
              <td class="px-3 py-3 align-top text-sm" style="color: var(--text-secondary);">
                <%= user.designation || '—' %>
              </td>
              <td class="px-3 py-3 align-top text-sm whitespace-nowrap" style="color: var(--text-secondary);">
                <%= new Date(user.created_at).toLocaleDateString() %>
              </td>
              <td class="px-5 py-3 align-top text-right">
                <div class="flex items-center justify-center gap-1">
                  <a href="/users/<%= user.id %>/edit" class="icon-btn" data-tooltip="Edit user">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                    </svg>
                  </a>
                  <form method="POST" action="/users/<%= user.id %>/delete" class="inline delete-form">
                    <button type="button" class="icon-btn icon-btn-danger" data-tooltip="Delete user"
                      onclick="confirmDelete(this)">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                      </svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .filter-input {
    height: 34px;
    padding: 0 10px;
    font-size: 13px;
    border-radius: 7px;
    border: 1px solid var(--border-default);
    background: var(--bg-surface);
    color: var(--text-primary);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .filter-input:focus {
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 2px var(--accent-soft);
  }
  .filter-input::placeholder {
    color: var(--text-muted);
  }
  .user-search-wrap .filter-input {
    padding-left: 2.25rem;
  }
  .user-search-icon {
    position: absolute;
    left: 0.7rem;
    top: 0;
    bottom: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .user-search-icon svg {
    display: block;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    height: 34px;
    padding: 0 12px;
    font-size: 13px;
    font-weight: 500;
    border-radius: 7px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.15s, color 0.15s;
  }
  .filter-btn-apply {
    background: var(--accent-primary);
    color: var(--color-dark);
  }
  .filter-btn-apply:hover {
    background: var(--accent-hover);
  }
  .filter-btn-reset {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border-default);
  }
  .filter-btn-reset:hover {
    background: var(--bg-muted);
    color: var(--text-primary);
  }

  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: none;
    background: none;
    color: var(--text-secondary);
    cursor: pointer;
    position: relative;
    transition: background-color 0.15s, color 0.15s;
  }
  .icon-btn:hover {
    background-color: var(--bg-soft);
    color: var(--color-dark);
  }
  .icon-btn-danger:hover {
    background-color: #fef2f2;
    color: #dc2626;
  }

  .icon-btn[data-tooltip]::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) scale(0.92);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
    background-color: var(--color-dark);
    color: #fff;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s, transform 0.15s;
  }
  .icon-btn[data-tooltip]::before {
    content: '';
    position: absolute;
    bottom: calc(100% + 2px);
    left: 50%;
    transform: translateX(-50%) scale(0.92);
    border: 4px solid transparent;
    border-top-color: var(--color-dark);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s, transform 0.15s;
  }
  .icon-btn[data-tooltip]:hover::after,
  .icon-btn[data-tooltip]:hover::before {
    opacity: 1;
    transform: translateX(-50%) scale(1);
  }
</style>

<script>
  function confirmDelete(btn) {
    var form = btn.closest('form');
    AlertModal.confirm(
      'Delete User',
      'Are you sure? This will also delete all tasks assigned to this user.',
      function (confirmed) { if (confirmed) form.submit(); }
    );
  }
</script>

<%- include('../partials/footer') %>
