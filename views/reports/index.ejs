<%- include('../partials/header') %>

<%
  const reportUsers = (users || []).map((u) => ({ id: u.id, name: u.name, meta: (u.role || '').toUpperCase() }));
  const selectedUserIds = Array.isArray(filters.user_ids) ? filters.user_ids : [];
  const selectedKpiIds = Array.isArray(filters.kpi_category_ids) ? filters.kpi_category_ids : [];
%>

<section class="space-y-7 report-page">
  <div class="report-hero card">
    <div class="report-hero-left">
      <p class="report-eyebrow">Analytics Workspace</p>
      <h1 class="report-title">Reports</h1>
      <p class="report-subtitle">Generate productivity reports across staff and admins with flexible filters.</p>
    </div>
    <div class="report-hero-right">
      <div class="hero-chip">
        <span class="hero-chip-label">Assignments</span>
        <span class="hero-chip-value"><%= totals.assigned || 0 %></span>
      </div>
      <div class="hero-chip">
        <span class="hero-chip-label">Submitted</span>
        <span class="hero-chip-value"><%= totals.submitted || 0 %></span>
      </div>
      <div class="hero-chip">
        <span class="hero-chip-label">Completion Rate</span>
        <span class="hero-chip-value"><%= Number(totals.completion_rate || 0).toFixed(1) %>%</span>
      </div>
    </div>
  </div>

  <div class="card report-filters">
    <form method="GET" action="/reports" class="space-y-5">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 report-selector-grid">
        <div class="report-selector-block">
          <label class="form-label mb-2 block">Users</label>
          <%- include('../partials/staff-multiselect', {
            staff: reportUsers,
            selectedIds: selectedUserIds,
            inputName: 'user_ids',
            inputId: 'reports-users',
            placeholderText: 'Choose users...',
            searchPlaceholder: 'Search users...'
          }) %>
          <p class="report-helper">Leave empty to include everyone.</p>
        </div>

        <div class="report-selector-block">
          <label class="form-label mb-2 block">KPI Categories</label>
          <%- include('../partials/kpi-multiselect', {
            categories: kpiCategories || [],
            selectedIds: selectedKpiIds,
            inputName: 'kpi_category_ids',
            inputId: 'reports-kpi',
            placeholderText: 'Choose KPI categories...',
            searchPlaceholder: 'Search KPI...'
          }) %>
          <p class="report-helper">Pick one or multiple KPI categories.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 items-end">
        <div>
          <label class="form-label" for="start_date">Start Date</label>
          <input type="date" id="start_date" name="start_date" class="input-field" value="<%= filters.start_date || '' %>" />
        </div>
        <div>
          <label class="form-label" for="end_date">End Date</label>
          <input type="date" id="end_date" name="end_date" class="input-field" value="<%= filters.end_date || '' %>" />
        </div>
        <div class="report-kpi-box">
          <p class="report-kpi-label">Pending Submission</p>
          <p class="report-kpi-value"><%= totals.pending || 0 %></p>
        </div>
        <div class="report-actions">
          <button type="submit" class="btn-primary w-full sm:w-auto">Generate Report</button>
          <a href="/reports" class="btn-secondary w-full sm:w-auto text-center">Reset</a>
        </div>
      </div>
    </form>
  </div>

  <div class="card overflow-hidden" style="padding: 0;">
    <div class="report-section-head">
      <h2>Summary by User</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr style="background-color: var(--bg-surface); border-bottom: 1px solid var(--border-light);">
            <th class="px-5 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">User</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Role</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Assigned</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Submitted</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Pending</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Overdue</th>
            <th class="px-5 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Completion Rate</th>
          </tr>
        </thead>
        <tbody>
          <% if (!summaryRows || summaryRows.length === 0) { %>
            <tr>
              <td colspan="7" class="px-5 py-10 text-center text-sm" style="color: var(--text-muted);">No summary data for the selected filters.</td>
            </tr>
          <% } %>
          <% (summaryRows || []).forEach((row) => { %>
            <tr class="table-row">
              <td class="px-5 py-3 align-top font-medium" style="color: var(--text-primary);"><%= row.user_name %></td>
              <td class="px-3 py-3 align-top text-xs capitalize" style="color: var(--text-secondary);"><%= row.user_role %></td>
              <td class="px-3 py-3 align-top"><%= row.assigned_count %></td>
              <td class="px-3 py-3 align-top"><%= row.submitted_count %></td>
              <td class="px-3 py-3 align-top"><%= row.pending_submission_count %></td>
              <td class="px-3 py-3 align-top"><%= row.overdue_count %></td>
              <td class="px-5 py-3 align-top">
                <span class="rate-pill"><%= Number(row.completion_rate || 0).toFixed(1) %>%</span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card overflow-hidden" style="padding: 0;">
    <div class="report-section-head">
      <h2>Detailed Assignments</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr style="background-color: var(--bg-surface); border-bottom: 1px solid var(--border-light);">
            <th class="px-5 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">User</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Task</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">KPI</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Task Status</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Submission</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Prof</th>
            <th class="px-5 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Due Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (!taskRows || taskRows.length === 0) { %>
            <tr>
              <td colspan="7" class="px-5 py-10 text-center text-sm" style="color: var(--text-muted);">No detailed rows for the selected filters.</td>
            </tr>
          <% } %>
          <% (taskRows || []).forEach((row) => { %>
            <tr class="table-row">
              <td class="px-5 py-3 align-top font-medium" style="color: var(--text-primary);">
                <%= row.user_name %>
                <span class="text-xs capitalize" style="color: var(--text-muted);">(<%= row.user_role %>)</span>
              </td>
              <td class="px-3 py-3 align-top" style="color: var(--text-primary);"><%= row.task_title %></td>
              <td class="px-3 py-3 align-top" style="color: var(--text-secondary);"><%= row.kpi_name %></td>
              <td class="px-3 py-3 align-top">
                <% if (row.task_status === 'pending') { %>
                  <span class="badge badge-pending">Pending</span>
                <% } else if (row.task_status === 'in_progress') { %>
                  <span class="badge badge-in-progress">In Progress</span>
                <% } else { %>
                  <span class="badge badge-completed">Completed</span>
                <% } %>
              </td>
              <td class="px-3 py-3 align-top">
                <% if (row.completion_status === 'submitted') { %>
                  <span class="badge badge-completed">Submitted</span>
                <% } else { %>
                  <span class="badge badge-pending">Not Submitted</span>
                <% } %>
              </td>
              <td class="px-3 py-3 align-top">
                <% if (row.proof_path) { %>
                  <a href="/<%= row.proof_path %>" target="_blank" rel="noopener noreferrer" class="prof-link">View prof</a>
                <% } else { %>
                  <em class="no-prof-text">no prof submitted</em>
                <% } %>
              </td>
              <td class="px-5 py-3 align-top" style="color: var(--text-secondary);"><%= new Date(row.due_date).toLocaleDateString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .report-page {
    background:
      radial-gradient(1200px 400px at -10% -10%, rgba(87, 146, 127, 0.12), transparent 55%),
      radial-gradient(800px 300px at 110% 10%, rgba(219, 199, 150, 0.16), transparent 52%);
    padding: 2px;
    border-radius: 18px;
  }
  .report-hero {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
    border: 1px solid #dce7e2;
    background: linear-gradient(130deg, #f7fbf9 0%, #eef6f2 52%, #fdf8ee 100%);
  }
  .report-eyebrow {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #5f7d74;
    font-weight: 600;
  }
  .report-title {
    font-size: clamp(28px, 4vw, 38px);
    line-height: 1;
    letter-spacing: -0.03em;
    color: #23463d;
    margin-top: 2px;
    font-weight: 700;
  }
  .report-subtitle {
    margin-top: 8px;
    color: #46645d;
    max-width: 560px;
    font-size: 14px;
  }
  .report-hero-right {
    display: grid;
    grid-template-columns: repeat(3, minmax(110px, 1fr));
    gap: 10px;
    width: min(430px, 100%);
  }
  .hero-chip {
    border-radius: 12px;
    border: 1px solid #d8e6de;
    background: #ffffff;
    padding: 10px 12px;
    box-shadow: 0 1px 2px rgba(11, 24, 21, 0.03);
  }
  .hero-chip-label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #607b73;
    font-weight: 600;
  }
  .hero-chip-value {
    display: block;
    margin-top: 2px;
    color: #1f3d35;
    font-size: 20px;
    font-weight: 600;
  }

  .report-filters {
    border: 1px solid var(--border-light);
    background: linear-gradient(180deg, #ffffff 0%, #f8fbfa 100%);
  }
  .report-helper {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 6px;
  }
  .report-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .report-kpi-box {
    border: 1px solid var(--border-light);
    border-radius: 10px;
    background: #ffffff;
    padding: 8px 10px;
  }
  .report-kpi-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    font-weight: 700;
  }
  .report-kpi-value {
    font-size: 20px;
    color: var(--text-primary);
    font-weight: 600;
    line-height: 1.1;
    margin-top: 2px;
  }

  .report-section-head {
    padding: 12px 20px;
    border-bottom: 1px solid var(--border-light);
    background: linear-gradient(180deg, #fbfdfc 0%, #f4f8f7 100%);
  }
  .report-section-head h2 {
    color: var(--text-primary);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .rate-pill {
    display: inline-flex;
    padding: 4px 8px;
    border-radius: 999px;
    background: #ecf8f2;
    color: #22614f;
    font-weight: 600;
    font-size: 12px;
  }
  .report-selector-grid {
    column-gap: 1.5rem;
    row-gap: 1rem;
  }
  .report-selector-block {
    padding: 4px 2px 6px;
  }
  .prof-link {
    color: var(--color-soft);
    text-decoration: underline;
    font-size: 12px;
  }
  .no-prof-text {
    color: var(--text-muted);
    font-size: 12px;
  }

  @media (max-width: 900px) {
    .report-hero-right {
      grid-template-columns: repeat(3, 1fr);
      width: 100%;
    }
    .report-actions {
      justify-content: flex-start;
    }
  }
  @media (max-width: 560px) {
    .report-hero-right {
      grid-template-columns: 1fr;
    }
  }
</style>

<%- include('../partials/footer') %>
