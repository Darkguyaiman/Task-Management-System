<%- include('../partials/header') %>

<section class="space-y-8">
  <div>
    <h1 class="page-title">Tasks</h1>
    <p class="page-subtitle">Create and manage tasks, and control who they are assigned to.</p>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.1fr)_minmax(0,1.6fr)] gap-6">
    <div class="space-y-6">
      <div class="card space-y-4">
        <h2 class="text-sm font-semibold" style="color: var(--color-dark);">Create Task</h2>

        <% if (formError) { %>
          <div class="error-alert"><%= formError %></div>
        <% } %>

        <form method="POST" action="/tasks" class="space-y-4">
          <div>
            <label class="form-label" for="user_id">User</label>
            <select id="user_id" name="user_id" required class="input-field">
              <option value="">Choose user</option>
              <% users.forEach((user) => { %>
                <option value="<%= user.id %>" <%= String(oldInput.user_id || '') === String(user.id) ? 'selected' : '' %>>
                  <%= user.name %> (<%= user.email %>)
                </option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="form-label" for="kpi_category_id">KPI Category</label>
            <select id="kpi_category_id" name="kpi_category_id" required class="input-field">
              <option value="">Choose category</option>
              <% categories.forEach((category) => { %>
                <option value="<%= category.id %>" <%= String(oldInput.kpi_category_id || '') === String(category.id) ? 'selected' : '' %>>
                  <%= category.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="form-label" for="title">Title</label>
            <input id="title" name="title" required class="input-field"
              value="<%= oldInput.title || '' %>" />
          </div>

          <div>
            <label class="form-label" for="description">Description</label>
            <textarea id="description" name="description" rows="3"
              class="input-field resize-y"><%= oldInput.description || '' %></textarea>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="form-label" for="status">Status</label>
              <select id="status" name="status" required class="input-field">
                <option value="pending" <%= (oldInput.status || '') === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="in_progress" <%= (oldInput.status || '') === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                <option value="completed" <%= (oldInput.status || '') === 'completed' ? 'selected' : '' %>>Completed</option>
              </select>
            </div>
            <div>
              <label class="form-label" for="due_date">Due Date</label>
              <input id="due_date" name="due_date" type="date" required class="input-field"
                value="<%= oldInput.due_date || '' %>" />
            </div>
          </div>

          <div class="pt-1">
            <button type="submit" class="btn-primary">Create Task</button>
          </div>
        </form>
      </div>

      <div class="card space-y-4">
        <h2 class="text-sm font-semibold" style="color: var(--color-dark);">Filters</h2>
        <form method="GET" action="/tasks" class="space-y-4">
          <div>
            <label class="form-label" for="filter_user">User</label>
            <select id="filter_user" name="user_id" class="input-field">
              <option value="">All users</option>
              <% users.forEach((user) => { %>
                <option value="<%= user.id %>" <%= String(filters.user_id || '') === String(user.id) ? 'selected' : '' %>>
                  <%= user.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="form-label" for="filter_status">Status</label>
            <select id="filter_status" name="status" class="input-field">
              <option value="">All statuses</option>
              <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
              <option value="in_progress" <%= filters.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
              <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
            </select>
          </div>

          <div>
            <label class="form-label" for="filter_due_date">Due Date</label>
            <input id="filter_due_date" name="due_date" type="date" class="input-field"
              value="<%= filters.due_date || '' %>" />
          </div>

          <div class="flex gap-2">
            <button type="submit" class="btn-secondary flex-1">Apply</button>
            <a href="/tasks" class="btn-ghost flex-1 text-center">Reset</a>
          </div>
        </form>
      </div>
    </div>

    <div class="card space-y-4 overflow-hidden">
      <div>
        <h2 class="text-sm font-semibold" style="color: var(--color-dark);">Task List</h2>
        <p class="text-xs mt-0.5" style="color: var(--text-muted);">
          <%= tasks.length %> task<%= tasks.length !== 1 ? 's' : '' %> found.
        </p>
      </div>

      <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm" style="border-top: 1px solid var(--border-light);">
          <thead>
            <tr style="background-color: var(--bg-soft);">
              <th class="px-5 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">ID</th>
              <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Title</th>
              <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">User</th>
              <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">KPI</th>
              <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Status</th>
              <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Due</th>
              <th class="px-5 py-2.5 text-right text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (tasks.length === 0) { %>
              <tr>
                <td colspan="7" class="px-5 py-10 text-center text-sm" style="color: var(--text-muted);">
                  No tasks found. Create one or adjust your filters.
                </td>
              </tr>
            <% } %>
            <% tasks.forEach((task) => { %>
              <tr class="table-row">
                <td class="px-5 py-3 align-top text-xs whitespace-nowrap" style="color: var(--text-muted);">#<%= task.id %></td>
                <td class="px-3 py-3 align-top">
                  <div class="text-sm font-medium" style="color: var(--text-primary);"><%= task.title %></div>
                  <% if (task.description) { %>
                    <div class="text-xs mt-0.5" style="color: var(--text-muted);"><%= task.description %></div>
                  <% } %>
                </td>
                <td class="px-3 py-3 align-top text-sm whitespace-nowrap"><%= task.user_name %></td>
                <td class="px-3 py-3 align-top text-sm whitespace-nowrap"><%= task.kpi_category_name %></td>
                <td class="px-3 py-3 align-top">
                  <% if (task.status === 'pending') { %>
                    <span class="badge badge-pending">Pending</span>
                  <% } else if (task.status === 'in_progress') { %>
                    <span class="badge badge-in-progress">In Progress</span>
                  <% } else if (task.status === 'completed') { %>
                    <span class="badge badge-completed">Completed</span>
                  <% } else { %>
                    <span class="badge" style="background-color: var(--bg-soft); color: var(--text-secondary);"><%= task.status %></span>
                  <% } %>
                </td>
                <td class="px-3 py-3 align-top text-sm whitespace-nowrap">
                  <%= new Date(task.due_date).toLocaleDateString() %>
                </td>
                <td class="px-5 py-3 align-top text-right whitespace-nowrap">
                  <div class="flex items-center justify-end gap-2">
                    <a href="/tasks/<%= task.id %>/edit" class="btn-sm-edit">Edit</a>
                    <form method="POST" action="/tasks/<%= task.id %>/delete" class="inline">
                      <button type="submit" class="btn-sm-danger"
                        onclick="return confirm('Delete this task?')">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
