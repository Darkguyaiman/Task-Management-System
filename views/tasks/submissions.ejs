<%- include('../partials/header') %>

<section class="space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="page-title">Task Submissions</h1>
      <p class="page-subtitle">
        <strong><%= task.title %></strong> - <%= task.kpi_category_name %> - Due <%= new Date(task.due_date).toLocaleDateString() %>
      </p>
    </div>
    <a href="/tasks" class="btn-secondary">Back to Tasks</a>
  </div>

  <div class="card overflow-hidden" style="padding: 0;">
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr style="background-color: var(--bg-surface); border-bottom: 1px solid var(--border-light);">
            <th class="px-5 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Staff</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Role</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Submission</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Proof</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Submitted At</th>
            <th class="px-5 py-2.5 text-center text-xs font-medium uppercase tracking-wide" style="color: var(--text-secondary);">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if ((submissions || []).length === 0) { %>
            <tr>
              <td colspan="6" class="px-5 py-10 text-center text-sm" style="color: var(--text-muted);">No assignments for this task yet.</td>
            </tr>
          <% } %>

          <% (submissions || []).forEach((row) => { %>
            <tr class="table-row">
              <td class="px-5 py-3 align-top text-sm font-medium" style="color: var(--text-primary);"><%= row.user_name %></td>
              <td class="px-3 py-3 align-top text-xs capitalize" style="color: var(--text-secondary);"><%= row.user_role %></td>
              <td class="px-3 py-3 align-top">
                <% if (row.completion_status === 'submitted') { %>
                  <span class="badge badge-completed">Submitted</span>
                <% } else { %>
                  <span class="badge badge-pending">Not Submitted</span>
                <% } %>
              </td>
              <td class="px-3 py-3 align-top text-xs" style="color: var(--text-secondary);">
                <% if (row.proof_path) { %>
                  <a href="/<%= row.proof_path %>" target="_blank" rel="noopener noreferrer" class="proof-file-link">
                    <%= row.proof_original_name || 'View proof file' %>
                  </a>
                  <% if (row.proof_size_bytes) { %>
                    <div class="mt-1" style="color: var(--text-muted);"><%= Math.ceil(row.proof_size_bytes / 1024) %> KB</div>
                  <% } %>
                <% } else { %>
                  <span style="color: var(--text-muted);">-</span>
                <% } %>
              </td>
              <td class="px-3 py-3 align-top text-xs whitespace-nowrap" style="color: var(--text-secondary);">
                <%= row.completion_submitted_at ? new Date(row.completion_submitted_at).toLocaleString() : '-' %>
              </td>
              <td class="px-5 py-3 align-top text-right">
                <% if (row.completion_status === 'submitted') { %>
                  <form method="POST" action="/tasks/<%= task.id %>/staff/<%= row.user_id %>/reopen" class="inline reopen-form">
                    <button
                      type="button"
                      class="btn-sm-danger"
                      data-staff-name="<%- (row.user_name || '').replace(/&/g, '&amp;').replace(/\"/g, '&quot;') %>"
                      data-file-name="<%- (row.proof_original_name || 'the original proof file').replace(/&/g, '&amp;').replace(/\"/g, '&quot;') %>"
                      onclick="confirmReopenSubmission(this)">
                      Reopen
                    </button>
                  </form>
                <% } else { %>
                  <span class="text-xs" style="color: var(--text-muted);">No action</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .proof-file-link {
    color: var(--color-soft);
    text-decoration: underline;
    display: inline-block;
    max-width: 260px;
    overflow-wrap: anywhere;
    word-break: break-word;
    line-height: 1.35;
    vertical-align: top;
  }
</style>

<script>
  function confirmReopenSubmission(btn) {
    var form = btn.closest('form');
    var staffName = btn.getAttribute('data-staff-name') || 'this user';
    var fileName = btn.getAttribute('data-file-name') || 'the original proof file';
    var message = 'Reopening will allow ' + staffName + ' to submit again.';
    if (fileName && fileName !== 'the original proof file') {
      message += '\n\nWhen they upload a new file, it will permanently delete ' + fileName + '.';
    } else {
      message += '\n\nWhen they upload a new file, it will permanently delete the previous proof file.';
    }
    message += '\n\nContinue?';
    AlertModal.confirm(
      'Reopen Submission',
      message,
      function (confirmed) { if (confirmed) form.submit(); },
      'Continue'
    );
  }
</script>

<%- include('../partials/footer') %>
