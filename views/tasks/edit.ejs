<%- include('../partials/header') %>

<%
  const selectedKpiIds = Array.isArray(selectedKpiCategoryIds)
    ? selectedKpiCategoryIds
    : (task && task.kpi_category_id ? [task.kpi_category_id] : []);
%>

<section class="space-y-8">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="page-title">Edit Task #<%= task.id %></h1>
      <p class="page-subtitle">Update task details and assignment.</p>
    </div>
    <a href="/tasks" class="btn-ghost">Back to Tasks</a>
  </div>

  <div class="max-w-2xl">
    <div class="card space-y-5">
      <% if (formError) { %>
        <div class="error-alert"><%= formError %></div>
      <% } %>

      <form method="POST" action="/tasks/<%= task.id %>/update" class="space-y-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label" for="user_id">User</label>
            <select id="user_id" name="user_id" required class="input-field">
              <% users.forEach((user) => { %>
                <option value="<%= user.id %>" <%= String(task.user_id) === String(user.id) ? 'selected' : '' %>>
                  <%= user.name %> (<%= user.email %>)
                </option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="form-label">KPI Categories</label>
            <%- include('../partials/kpi-multiselect', {
              categories: categories || [],
              selectedIds: selectedKpiIds,
              inputName: 'kpi_category_ids',
              inputId: 'task-edit-legacy',
              placeholderText: 'Choose KPI categories...',
              searchPlaceholder: 'Search KPI categories...'
            }) %>
          </div>
        </div>

        <div>
          <label class="form-label" for="title">Title</label>
          <input id="title" name="title" required class="input-field" value="<%= task.title %>" />
        </div>

        <div>
          <label class="form-label" for="description">Description</label>
          <textarea id="description" name="description" rows="4" class="input-field resize-y"><%= task.description || '' %></textarea>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label" for="status">Status</label>
            <select id="status" name="status" required class="input-field">
              <option value="pending" <%= task.status === 'pending' ? 'selected' : '' %>>Pending</option>
              <option value="in_progress" <%= task.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
              <option value="completed" <%= task.status === 'completed' ? 'selected' : '' %>>Completed</option>
            </select>
          </div>

          <div>
            <label class="form-label" for="due_date">Due Date</label>
            <input id="due_date" name="due_date" type="date" required class="input-field"
              value="<%= new Date(task.due_date).toISOString().split('T')[0] %>" />
          </div>
        </div>

        <div class="flex items-center gap-3 pt-2">
          <button type="submit" class="btn-primary">Update Task</button>
          <a href="/tasks" class="btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
